//@version=6
indicator("TD Sequential – Setup", overlay=true, max_labels_count=500)

// ── Inputs ────────────────────────────────────────────────────────────────────
show_1_8  = input.bool(false,         "Show bars 1–8 after setup completes", group="Setup")
use_equal = input.bool(false,        "Include equal (≤ / ≥) in setup comparison", group="Setup")
enable_perfect_setup = input.bool(true,        "Enable perfect setup", group="Setup")
setup_len = input.int(9, "Setup Length (min 9)", minval=9, group="Setup")
look_back  = input.int(4, "Lookback Bars (min 4)", minval=4, group="Setup")
font_size = input.int(20, "Label Font Size", group="Setup")
buy_color = input.color(color.rgb(237, 165, 166), "Buy Setup Color",                     group="Colors")
sell_color = input.color(color.rgb(82, 255, 134),   "Sell Setup Color",                    group="Colors")

// ── State ─────────────────────────────────────────────────────────────────────
var int            buy_cnt  = 0
var int            sel_cnt  = 0
var bool           buy_done = false
var bool           sel_done = false
var array<int>     buy_bi  = array.new<int>(setup_len, 0)
var array<float>   buy_lo  = array.new<float>(setup_len, 0.0)
var array<int>     sel_bi  = array.new<int>(setup_len, 0)
var array<float>   sel_hi  = array.new<float>(setup_len, 0.0)

// 完美化信号触发变量
bool isBuyPerfected = false
bool isSellPerfected = false

// ── Buy Setup ────────────────────────────────────────────────────────────────
buy_cond = use_equal ? close <= close[look_back] : close < close[look_back]

if buy_cond
    if not buy_done
        buy_cnt += 1
        array.set(buy_bi, buy_cnt - 1, bar_index)
        array.set(buy_lo, buy_cnt - 1, low)
        if buy_cnt == setup_len
            buy_done := true
            // 判定 Perfected Buy: 8或9的Low < 6和7的Low
            min67 = math.min(low[2], low[3])
            if low < min67 or low[1] < min67
                isBuyPerfected := true

            for i = (show_1_8 ? 0 : setup_len - 1) to setup_len - 1
                string label_txt = str.tostring(i + 1)
                if enable_perfect_setup
                    if i == setup_len - 1 and isBuyPerfected
                        label_txt := '9\n▲'
                        label_txt
                label.new(
                  x         = array.get(buy_bi, i),
                  y         = array.get(buy_lo, i),
                  text      = label_txt,
                  xloc      = xloc.bar_index,
                  yloc      = yloc.price,
                  color     = color.new(color.white, 100),
                  textcolor = buy_color,
                  style     = label.style_label_up,
                  size      = font_size)
else
    buy_cnt  := 0
    buy_done := false

// ── Sell Setup ───────────────────────────────────────────────────────────────
sel_cond = use_equal ? close >= close[look_back] : close > close[look_back]

if sel_cond
    if not sel_done
        sel_cnt += 1
        array.set(sel_bi, sel_cnt - 1, bar_index)
        array.set(sel_hi, sel_cnt - 1, high)
        if sel_cnt == setup_len
            sel_done := true
            // 判定 Perfected Sell: 8或9的High > 6和7的High
            max67 = math.max(high[2], high[3])
            if high > max67 or high[1] > max67
                isSellPerfected := true

            for i = (show_1_8 ? 0 : setup_len - 1) to setup_len - 1
                string label_txt = str.tostring(i + 1)
                if enable_perfect_setup
                    if i == setup_len - 1 and isSellPerfected
                        label_txt := '▼\n9'
                        label_txt
                label.new(
                  x         = array.get(sel_bi, i),
                  y         = array.get(sel_hi, i),
                  text      = label_txt,
                  xloc      = xloc.bar_index,
                  yloc      = yloc.price,
                  color     = color.new(color.white, 100),
                  textcolor = sell_color,
                  style     = label.style_label_down,
                  size      = font_size)
else
    sel_cnt  := 0
    sel_done := false
