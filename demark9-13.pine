//@version=6
indicator("TD Sequential – Setup", overlay=true, max_labels_count=500, max_lines_count=500, max_bars_back=5000)

// ── Inputs ────────────────────────────────────────────────────────────────────
enable_setup  = input.bool(false,         "Show setup", group="Setup", display = display.none)
show_all_bars = input.string("Active only", "Show all counts", options=["Active only", "All"], group="Setup", display = display.none)//  setup和countdown公用这个

use_equal = input.bool(false,        "Include equal (≤ / ≥) in setup comparison", group="Setup", display = display.none)
enable_perfect_setup = input.bool(true,        "Enable perfect setup", group="Setup", display = display.none)
setup_len = input.int(9, "Setup Length (min 9)", minval=9, group="Setup", display = display.none)
look_back  = input.int(4, "Lookback Bars (min 4)", minval=4, group="Setup", display = display.none)
font_size = input.int(20, "Label Font Size", group="Setup", display = display.none)
label_bold = input.string("Bold", "Label Style", options=["Bold", "Normal"], group="Setup", display = display.none)

// buy_color = input.color(color.rgb(237, 165, 166), "Buy Setup Color",                     group="Colors", display = display.none)
// sell_color = input.color(color.rgb(82, 255, 134),   "Sell Setup Color",                    group="Colors", display = display.none)
buy_color  = input.color(color.rgb(199, 146, 248), "Buy Setup Color",  group="Colors", display = display.none)
sell_color = input.color(color.rgb(25,  140, 248), "Sell Setup Color", group="Colors", display = display.none)
show_tdst      = input.bool(true,              "Show TDST",                  group="TDST", display = display.none)
// tdst_res_color = input.color(color.rgb(199, 146, 248), "TDST Resistance Color", group="TDST", display = display.none)
// tdst_sup_color = input.color(color.rgb(25,  140, 248), "TDST Support Color",    group="TDST", display = display.none)
tdst_res_color = input.color(color.rgb(4, 4, 4), "TDST Resistance Color", group="TDST", display = display.none)
tdst_sup_color = input.color(color.rgb(2, 2, 2), "TDST Support Color",    group="TDST", display = display.none)
tdst_line_weight = input.int(3, "TDST line weight", group="TDST", display = display.none)
show_risk_level  = input.bool(true, "Show Setup Risk Level", group="Risk Level", display = display.none)
risk_level_line_weight = input.int(2, "Risk level line weight", group="TDST", display = display.none)
show_risk_zone      = input.bool(true, "Show Risk Level Zone",  group="Risk Level", display = display.none)
risk_buy_zone_color = input.color(color.new(color.rgb(2,  2, 2), 95), "Buy Zone Color",  group="Risk Level", display = display.none)
risk_sel_zone_color = input.color(color.new(color.rgb(2,  2, 2), 95), "Sell Zone Color", group="Risk Level", display = display.none)

enable_sequential_countdown  = input.bool(false,                      "Enable Sequential Countdown",       group="Countdown", display = display.none)
cd_buy_color      = input.color(color.rgb(199, 146, 248),  "Buy Countdown Color",               group="Countdown", display = display.none)
cd_sell_color     = input.color(color.rgb(25,  140, 248),  "Sell Countdown Color",              group="Countdown", display = display.none)
cd_bars           = input.int(13,        "Bars to Countdown",             minval=1, group="Countdown", display = display.none)
cd_look_back      = input.int(2,         "Bars to Look Back",             minval=1, group="Countdown", display = display.none)
cd_comp_val       = input.string("Close",       "Countdown Comparison Value",    options=["Close", "Low/High"],                          group="Countdown", display = display.none)
cd_term_val       = input.string("Open or Close",    "Termination Count Price Value", options=["Open or Close", "Close", "Low/High"],          group="Countdown", display = display.none)
cd_compare        = input.string("With Equals", "Countdown Compare",            options=["With Equals", "Without Equals"],               group="Countdown", display = display.none)

enable_breakout_qualifier = input.bool(false,        "Enable Breakout Qualifiers", group="Setup", display = display.none)

// ── State ─────────────────────────────────────────────────────────────────────
var int            buy_cnt  = 0
var int            sel_cnt  = 0
var bool           buy_done = false
var bool           sel_done = false
var array<int>     buy_bi  = array.new<int>(setup_len, 0)
var array<float>   buy_lo  = array.new<float>(setup_len, 0.0)
var array<float>   buy_hi  = array.new<float>(setup_len, 0.0) // Added for TDST
var array<float>   buy_tl  = array.new<float>(setup_len, 0.0) // true_low for risk level

var bool         buy_perf_wait = false   // waiting for deferred buy perfection
var float        buy_perf_ref  = na      // min(lo6, lo7) reference
var array<int>     sel_bi  = array.new<int>(setup_len, 0)
var array<float>   sel_hi  = array.new<float>(setup_len, 0.0)
var array<float>   sel_lo  = array.new<float>(setup_len, 0.0) // Added for TDST
var array<float>   sel_th  = array.new<float>(setup_len, 0.0) // true_high for risk level

var bool         sel_perf_wait = false   // waiting for deferred sell perfection
var float        sel_perf_ref  = na      // max(hi6, hi7) reference
var line         tdst_buy_line = na      // TDST resistance line (from buy setup)
var line         tdst_sel_line = na      // TDST support line (from sell setup)
var float        tdst_buy_price = na      // original price of active buy TDST (before offset)
var float        tdst_sel_price = na      // original price of active sell TDST (before offset)
var line         risk_buy_line  = na
var line         risk_sel_line  = na
var float        risk_buy_price = na
var float        risk_sel_price = na
var line         risk_buy_ref_line = na
var line         risk_sel_ref_line = na
var linefill     risk_buy_fill     = na
var linefill     risk_sel_fill     = na
// ── Buy Countdown State ───────────────────────────────────────────────────────
var bool  cd_buy_active     = false
var int   cd_buy_cnt        = 0
var float cd_buy_bar8_close = na
var array<int>   cd_buy_bi  = array.new<int>(13, 0)
var array<float> cd_buy_lo  = array.new<float>(13, 0.0)
// ── Sell Countdown State ──────────────────────────────────────────────────────
var bool  cd_sel_active     = false
var int   cd_sel_cnt        = 0
var float cd_sel_bar8_close = na
var array<int>   cd_sel_bi  = array.new<int>(13, 0)
var array<float> cd_sel_hi  = array.new<float>(13, 0.0)

var float offset = 0.01
var float tdst_offset = 0.002
var tdst_line_style = line.style_dashed
var tdst_line_break_style = line.style_solid
// var float tdst_offset = 0
// 完美化信号触发变量
bool isBuyPerfected = false
bool isSellPerfected = false

// ── True High / True Low ─────────────────────────────────────────────────────
true_high = math.max(high, nz(close[1], high))
true_low  = math.min(low,  nz(close[1], low))

// ── Buy Setup ────────────────────────────────────────────────────────────────
buy_cond = use_equal ? close <= close[look_back] : close < close[look_back]

if buy_cond
    if not buy_done
        buy_cnt += 1
        array.set(buy_bi, buy_cnt - 1, bar_index)
        array.set(buy_lo, buy_cnt - 1, low)
        array.set(buy_hi, buy_cnt - 1, true_high)
        array.set(buy_tl, buy_cnt - 1, true_low)

        if buy_cnt == setup_len
            buy_done := true
            cd_buy_active     := true
            cd_buy_cnt        := 0
            cd_buy_bar8_close := na
            cd_sel_active     := false
            cd_sel_cnt        := 0
            // 判定 Perfected Buy: 8或9的Low < 6和7的Low
            lo6   = array.get(buy_lo, setup_len - 4)
            lo7   = array.get(buy_lo, setup_len - 3)
            lo8   = array.get(buy_lo, setup_len - 2)
            lo9   = array.get(buy_lo, setup_len - 1)
            // min67 = math.min(low[2], low[3])
            min67 = math.min(lo6, lo7)
            if lo8 <= min67 or lo9 <= min67
                isBuyPerfected := true

            
            for i = (show_all_bars == "Active only" ? setup_len - 1 : 0) to setup_len - 1
                if i == setup_len - 1
                    // label_txt = 9 now
                    string label_txt = na
                    if enable_setup and enable_perfect_setup
                        if isBuyPerfected
                            label_txt := str.tostring(i + 1) + '\n▲'
                            label_txt
                        else
                            label_txt := str.tostring(i + 1)
                            label_txt
                    else if enable_setup and (not enable_perfect_setup)
                        label_txt := str.tostring(i + 1)
                        label_txt
                    else if (not enable_setup) and enable_perfect_setup
                        if isBuyPerfected
                            label_txt := '▲'
                            label_txt
                    // else if (not enable_setup) and (not enable_perfect_setup)
                    if not na(label_txt)
                        if label_bold == "Bold"
                            label.new(x = array.get(buy_bi, i), y = array.get(buy_lo, i) * (1 - offset), text = label_txt, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = buy_color, style = label.style_label_up, size = font_size, text_formatting=text.format_bold)
                        else
                            label.new(x = array.get(buy_bi, i), y = array.get(buy_lo, i) * (1 - offset), text = label_txt, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = buy_color, style = label.style_label_up, size = font_size, text_formatting=text.format_none)
                else 
                    if enable_setup
                        string label_txt = str.tostring(i + 1)
                        label.new(x = array.get(buy_bi, i), y = array.get(buy_lo, i) * (1 - offset), text = label_txt, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = buy_color, style = label.style_label_up, size = font_size, text_formatting=text.format_none)
            // if not immediately perfect, arm deferred watch
            if enable_perfect_setup and not isBuyPerfected
                buy_perf_wait := true
                buy_perf_ref  := min67
            // TDST resistance: highest high of this buy setup
            if show_tdst
                float setup_max_hi = array.max(buy_hi)
                tdst_buy_price := setup_max_hi
                float final_high = setup_max_hi * (1 + tdst_offset)
                int res_bar_index = array.get(buy_bi, array.indexof(buy_hi, setup_max_hi))
                if not na(tdst_buy_line)
                    line.set_x2(tdst_buy_line, res_bar_index)
                    line.set_extend(tdst_buy_line, extend.none)
                tdst_buy_line := line.new(res_bar_index, final_high, bar_index, final_high, extend=extend.none, color=tdst_res_color, style=tdst_line_style, width=tdst_line_weight)
            
            if show_risk_level
                float min_tl  = array.min(buy_tl)
                int   ext_idx = array.indexof(buy_tl, min_tl)
                float ext_th  = array.get(buy_hi, ext_idx)
                float rl      = min_tl - (ext_th - min_tl)
                float final_sell_risk_level = rl * (1 - tdst_offset)
                risk_buy_price := rl
                if not na(risk_buy_line)
                    line.set_x2(risk_buy_line, bar_index)
                    line.set_extend(risk_buy_line, extend.none)
                if not na(risk_buy_ref_line)
                    line.set_x2(risk_buy_ref_line, bar_index)
                    line.set_extend(risk_buy_ref_line, extend.none)
                if not na(risk_sel_line)
                    line.set_x2(risk_sel_line, bar_index)
                    line.set_extend(risk_sel_line, extend.none)
                    risk_sel_line := na
                if not na(risk_sel_ref_line)
                    line.set_x2(risk_sel_ref_line, bar_index)
                    line.set_extend(risk_sel_ref_line, extend.none)
                    risk_sel_ref_line := na
                risk_buy_line := line.new(bar_index, final_sell_risk_level, bar_index, final_sell_risk_level, extend=extend.none, color=tdst_res_color, style=line.style_dashed, width=risk_level_line_weight)
                if show_risk_zone
                    risk_buy_ref_line := line.new(bar_index, close, bar_index, close, extend=extend.none, color=color.new(color.white, 100), width=1)
                    risk_buy_fill := linefill.new(risk_buy_ref_line, risk_buy_line, color=risk_buy_zone_color)
            
else
    buy_cnt  := 0
    buy_done := false


// deferred buy perfection: runs every bar while armed
if buy_perf_wait and low <= buy_perf_ref
    if enable_perfect_setup
        label.new(x = bar_index, y = low * (1 - offset), text = "▲", xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = buy_color, style = label.style_label_up, size = font_size)
    buy_perf_wait := false

// ── Sell Setup ───────────────────────────────────────────────────────────────
sel_cond = use_equal ? close >= close[look_back] : close > close[look_back]
if sel_cond
    if not sel_done
        sel_cnt += 1
        array.set(sel_bi, sel_cnt - 1, bar_index)
        array.set(sel_hi, sel_cnt - 1, high)
        array.set(sel_lo, sel_cnt - 1, true_low)
        array.set(sel_th, sel_cnt - 1, true_high)

        if sel_cnt == setup_len
            sel_done := true
            cd_buy_active := false
            cd_buy_cnt    := 0
            cd_sel_active     := true
            cd_sel_cnt        := 0
            cd_sel_bar8_close := na
            // 判定 Perfected Sell: 8或9的High > 6和7的High
            // max67 = math.max(high[2], high[3])
            hi6   = array.get(sel_hi, setup_len - 4)
            hi7   = array.get(sel_hi, setup_len - 3)
            hi8   = array.get(sel_hi, setup_len - 2)
            hi9   = array.get(sel_hi, setup_len - 1)
            max67 = math.max(hi6, hi7)
            if hi8 >= max67 or hi9 >= max67
                isSellPerfected := true
            
            for i = (show_all_bars == "Active only" ? setup_len - 1 : 0) to setup_len - 1
                if i == setup_len - 1
                    // label_txt = 9 now
                    string label_txt = na
                    if enable_setup and enable_perfect_setup
                        if isSellPerfected
                            label_txt := '▼\n'+str.tostring(i + 1)
                            label_txt
                        else
                            label_txt := str.tostring(i + 1)
                            label_txt
                    else if enable_setup and (not enable_perfect_setup)
                        label_txt := str.tostring(i + 1)
                        label_txt
                    else if (not enable_setup) and enable_perfect_setup
                        if isSellPerfected
                            label_txt := '▼'
                            label_txt
                    // else if (not enable_setup) and (not enable_perfect_setup)
                    if not na(label_txt)
                        if label_bold == "Bold"
                            label.new(x = array.get(sel_bi, i), y = array.get(sel_hi, i)  * (1 + offset), text = label_txt, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = sell_color, style = label.style_label_down, size = font_size, text_formatting=text.format_bold)
                        else
                            label.new(x = array.get(sel_bi, i), y = array.get(sel_hi, i)  * (1 + offset), text = label_txt, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = sell_color, style = label.style_label_down, size = font_size, text_formatting=text.format_none)
                else 
                    if enable_setup
                        string label_txt = str.tostring(i + 1)
                        label.new(x = array.get(sel_bi, i), y = array.get(sel_hi, i)  * (1 + offset), text = label_txt, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = sell_color, style = label.style_label_down, size = font_size, text_formatting=text.format_none)
            // if not immediately perfect, arm deferred watch
            if enable_perfect_setup and not isSellPerfected
                sel_perf_wait := true
                sel_perf_ref  := max67

            if show_tdst
                float setup_min_lo = array.min(sel_lo)
                tdst_sel_price := setup_min_lo
                float final_low = setup_min_lo * (1 - tdst_offset)
                int support_bar_index = array.get(sel_bi, array.indexof(sel_lo, setup_min_lo))
                if not na(tdst_sel_line)
                    line.set_x2(tdst_sel_line, support_bar_index)
                    line.set_extend(tdst_sel_line, extend.none)
                tdst_sel_line := line.new(support_bar_index, final_low, bar_index, final_low, extend=extend.none, color=tdst_sup_color, style=tdst_line_style, width=tdst_line_weight)
            
            if show_risk_level
                float max_th  = array.max(sel_th)
                int   ext_idx = array.indexof(sel_th, max_th)
                float ext_tl  = array.get(sel_lo, ext_idx)
                float rl      = max_th + (max_th - ext_tl)
                float final_buy_risk_level = rl * (1 + tdst_offset)
                risk_sel_price := rl
                if not na(risk_sel_line)
                    line.set_x2(risk_sel_line, bar_index)
                    line.set_extend(risk_sel_line, extend.none)
                if not na(risk_sel_ref_line)
                    line.set_x2(risk_sel_ref_line, bar_index)
                    line.set_extend(risk_sel_ref_line, extend.none)
                if not na(risk_buy_line)
                    line.set_x2(risk_buy_line, bar_index)
                    line.set_extend(risk_buy_line, extend.none)
                    risk_buy_line := na
                if not na(risk_buy_ref_line)
                    line.set_x2(risk_buy_ref_line, bar_index)
                    line.set_extend(risk_buy_ref_line, extend.none)
                    risk_buy_ref_line := na
                risk_sel_line := line.new(bar_index, final_buy_risk_level, bar_index, final_buy_risk_level, extend=extend.none, color=tdst_res_color, style=line.style_dashed, width=risk_level_line_weight)
                if show_risk_zone
                    risk_sel_ref_line := line.new(bar_index, close, bar_index, close, extend=extend.none, color=color.new(color.white, 100), width=1)
                    risk_sel_fill := linefill.new(risk_sel_line, risk_sel_ref_line, color=risk_sel_zone_color)
            
                
else
    sel_cnt  := 0
    sel_done := false

// deferred sell perfection: runs every bar while armed
if sel_perf_wait and high >= sel_perf_ref
    if enable_perfect_setup
        label.new(x = bar_index, y = high* (1 + offset), text = "▼", xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = sell_color, style = label.style_label_down, size = font_size)
    sel_perf_wait := false

// ── Extend active TDST lines to current bar, terminate if close crosses ──────
if not na(tdst_buy_line)
    line.set_x2(tdst_buy_line, bar_index)
    if close > tdst_buy_price
        line.set_style(tdst_buy_line, tdst_line_break_style)
        tdst_buy_line := na
        
        
if not na(tdst_sel_line)
    line.set_x2(tdst_sel_line, bar_index)
    if close < tdst_sel_price
        line.set_style(tdst_sel_line, tdst_line_break_style)
        tdst_sel_line := na
        

if not na(risk_buy_line)
    line.set_x2(risk_buy_line, bar_index)
    if not na(risk_buy_ref_line)
        line.set_x2(risk_buy_ref_line, bar_index)
    if close < risk_buy_price
        line.set_style(risk_buy_line, tdst_line_break_style)
        risk_buy_line := na
        risk_buy_ref_line := na
if not na(risk_sel_line)
    line.set_x2(risk_sel_line, bar_index)
    if not na(risk_sel_ref_line)
        line.set_x2(risk_sel_ref_line, bar_index)
    if close > risk_sel_price
        line.set_style(risk_sel_line, tdst_line_break_style)
        risk_sel_line := na
        risk_sel_ref_line := na


// ── Buy Countdown ─────────────────────────────────────────────────────────────
// Rules:
//   1. Arms after Buy Setup 9 completes; Bar 9 can simultaneously be CD Bar 1
//      if close <= low[2], otherwise waits for the first qualifying bar.
//   2. Counts bars where close <= low[cd_look_back] (cd_look_back default = 2).
//   3. At Bar 13: completion requires low[13] <= close[8] (condition 1).
//      Condition 2 (close <= low[2]) is implicit — only qualifying bars are counted.
//   4. Cancelled if a Sell Setup 9 completes while active.
if enable_sequential_countdown and cd_buy_active
    bool cd_cond = cd_compare == "With Equals" ? close <= low[cd_look_back] : close < low[cd_look_back]
    if cd_cond and cd_buy_cnt < 13
        cd_buy_cnt += 1
        array.set(cd_buy_bi, cd_buy_cnt - 1, bar_index)
        array.set(cd_buy_lo, cd_buy_cnt - 1, low)
        if cd_buy_cnt == 8
            cd_buy_bar8_close := close
        if cd_buy_cnt == 13
            // Condition 1: low of Bar 13 <= close of Bar 8
            if not na(cd_buy_bar8_close) and low <= cd_buy_bar8_close
                string countdown_label = str.tostring(cd_buy_cnt)
                label.new(x = bar_index, y = low * (1 - offset), text = countdown_label, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = cd_buy_color, style = label.style_label_up, size = font_size, text_formatting = text.format_bold)
            cd_buy_active := false
        else if show_all_bars == "All"
            label.new(x = bar_index, y = low * (1 - offset), text = str.tostring(cd_buy_cnt), xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = cd_buy_color, style = label.style_label_up, size = font_size, text_formatting = text.format_none)


// ── Sell Countdown ────────────────────────────────────────────────────────────
// Rules:
//   1. Arms after Sell Setup 9 completes; Bar 9 can simultaneously be CD Bar 1
//      if close >= high[2], otherwise waits for the first qualifying bar.
//   2. Counts bars where close >= high[cd_look_back] (cd_look_back default = 2).
//   3. At Bar 13: completion requires high[13] >= close[8] (condition 1).
//      Condition 2 (close >= high[2]) is implicit — only qualifying bars are counted.
//   4. Cancelled if a Buy Setup 9 completes while active.
if enable_sequential_countdown and cd_sel_active
    bool cd_sel_cond = cd_compare == "With Equals" ? close >= high[cd_look_back] : close > high[cd_look_back]
    if cd_sel_cond and cd_sel_cnt < 13
        cd_sel_cnt += 1
        array.set(cd_sel_bi, cd_sel_cnt - 1, bar_index)
        array.set(cd_sel_hi, cd_sel_cnt - 1, high)
        if cd_sel_cnt == 8
            cd_sel_bar8_close := close
        if cd_sel_cnt == 13
            // Condition 1: high of Bar 13 >= close of Bar 8
            if not na(cd_sel_bar8_close) and high >= cd_sel_bar8_close
                string countdown_label = str.tostring(cd_sel_cnt)
                label.new(x = bar_index, y = high * (1 + offset), text = countdown_label, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = cd_sell_color, style = label.style_label_down, size = font_size, text_formatting = text.format_bold)
            cd_sel_active := false
        else if show_all_bars == "All"
            label.new(x = bar_index, y = high * (1 + offset), text = str.tostring(cd_sel_cnt), xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = cd_sell_color, style = label.style_label_down, size = font_size, text_formatting = text.format_none)

