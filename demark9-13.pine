//@version=6
indicator("TD-Claude", overlay=true, max_labels_count=500, max_lines_count=500, max_bars_back=5000, behind_chart = false)

// ── Inputs ────────────────────────────────────────────────────────────────────
enable_setup  = input.bool(false,         "Setup", inline="setup_row", display = display.none)
setup_buy_color     = input.color(color.rgb(199, 146, 248), "Buy", inline="setup_row", display = display.none)
setup_sell_color    = input.color(color.rgb(25,  140, 248), "Sell", inline="setup_row", display = display.none)

enable_tdst      = input.bool(false,              "TDST", inline = "tdst_row", display = display.none)
tdst_res_color = input.color(color.rgb(4, 4, 4), "Res", inline = "tdst_row", display = display.none)
tdst_sup_color = input.color(color.rgb(2, 2, 2), "Sup", inline = "tdst_row", display = display.none)

enable_sequential_countdown  = input.bool(false,                      "Sequential Countdown",       inline = "Sequential_countdown_row", display = display.none)
seq_cd_buy_color      = input.color(color.rgb(4, 4, 4),  "Buy",  inline = "Sequential_countdown_row", display = display.none)
seq_cd_sell_color     = input.color(color.rgb(4, 4, 4),  "Sell", inline = "Sequential_countdown_row", display = display.none)

enable_combo_countdown  = input.bool(false,                      "Combo Countdown",       inline = "Combo_countdown_row", display = display.none)
combo_cd_buy_color      = input.color(color.rgb(199, 146, 248),  "Buy",  inline = "Combo_countdown_row", display = display.none)
combo_cd_sell_color     = input.color(color.rgb(25,  140, 248),  "Sell", inline = "Combo_countdown_row", display = display.none)

font_size = input.int(20, "Label Font Size", display = display.none)
show_all_bars = input.string("Active only", "Show all counts", options=["Active only", "All"], display = display.none)//  setup和countdown公用这个


setup_len = input.int(9, "Setup Length (min 9)", minval=9, group="Setup", display = display.none)
setup_look_back  = input.int(4, "Lookback Bars (min 4)", minval=4, group="Setup", display = display.none)
setup_use_equal = input.string("Without equal", "Setup comparison", options=["Without equal", "With equal"], group="Setup", display = display.none)
label_bold = input.string("Bold", "Label Style", options=["Bold", "Normal"], group="Setup", display = display.none)
enable_perfect_setup = input.bool(false,        "Enable perfect setup", group="Setup", display = display.none)
enable_risk_level  = input.bool(false, "Enable Risk Level", group="Setup", display = display.none)
enable_risk_zone      = input.bool(false, "Enable Risk Level Zone",  group="Setup", display = display.none)
enable_price_flip      = input.bool(false, "Enable Price Flip",  group="Setup", display = display.none)

tdst_line_weight = input.int(3, "TDST line weight", group="TDST", display = display.none)
risk_level_line_weight = input.int(2, "Risk level line weight", group="TDST", display = display.none)
risk_buy_zone_color = input.color(color.new(color.rgb(2,  2, 2), 95), "Buy Zone Color",  group="Risk Level", display = display.none)
risk_sel_zone_color = input.color(color.new(color.rgb(2,  2, 2), 95), "Sell Zone Color", group="Risk Level", display = display.none)

cd_bars           = input.int(13,        "Bars to Countdown",             minval=1, group="Countdown (shared)", display = display.none)
cd_look_back      = input.int(2,         "Bars to Look Back",             minval=1, group="Countdown (shared)", display = display.none)
cd_comp_val       = input.string("Close",       "Countdown Comparison Value",    options=["Close", "Low/High"],                          group="Countdown (shared)", display = display.none)
cd_term_val       = input.string("Open or Close",    "Termination Count Price Value", options=["Open or Close", "Close", "Low/High"],          group="Countdown (shared)", display = display.none)
cd_compare        = input.string("With Equals", "Countdown Compare",            options=["With Equals", "Without Equals"],               group="Countdown (shared)", display = display.none)

enable_seq_intersection = input.bool(false,                      "Enable Intersection",       group="Sequential Countdown", display = display.none)
enable_8_vs_5 = input.bool(false,                      "8 vs 5 qualifier",       group="Sequential Countdown", display = display.none)
enable_13_vs_8 = input.bool(false,                      "Last vs 8 qualifier",       group="Sequential Countdown", display = display.none)
enable_seq_risk_level = input.bool(false,                      "Enable Risk Level",       group="Sequential Countdown", display = display.none)
enable_seq_risk_zone = input.bool(false,                      "Enable Risk Level Zone",       group="Sequential Countdown", display = display.none)

combo_version = input.string("Standard", "Combo version", options=["Standard", "Aggressive", "Conservative"], group="Combo Countdown",display = display.none)
enable_combo_risk_level = input.bool(false,                      "Enable Risk Level",       group="Combo Countdown", display = display.none)
enable_combo_risk_zone = input.bool(false,                      "Enable Risk Level Zone",       group="Combo Countdown", display = display.none)

enable_breakout_qualifier = input.bool(false,        "Enable Breakout Qualifiers", group="Breakout qualifiers", display = display.none)

// ── State ─────────────────────────────────────────────────────────────────────
cd_font_size = 20

var int            buy_cnt  = 0
var int            sel_cnt  = 0
var bool           buy_done = false
var bool           sel_done = false
var array<int>     buy_bi  = array.new<int>(setup_len, 0)
var array<float>   buy_lo  = array.new<float>(setup_len, 0.0)
var array<float>   buy_hi  = array.new<float>(setup_len, 0.0) // Added for TDST
var array<float>   buy_tl  = array.new<float>(setup_len, 0.0) // true_low for risk level

var bool         buy_perf_wait = false   // waiting for deferred buy perfection
var float        buy_perf_ref  = na      // min(lo6, lo7) reference
var array<int>     sel_bi  = array.new<int>(setup_len, 0)
var array<float>   sel_hi  = array.new<float>(setup_len, 0.0)
var array<float>   sel_lo  = array.new<float>(setup_len, 0.0) // Added for TDST
var array<float>   sel_th  = array.new<float>(setup_len, 0.0) // true_high for risk level

var bool         sel_perf_wait = false   // waiting for deferred sell perfection
var float        sel_perf_ref  = na      // max(hi6, hi7) reference
var line         tdst_buy_line = na      // TDST resistance line (from buy setup)
var line         tdst_sel_line = na      // TDST support line (from sell setup)
var float        tdst_buy_price = na      // original price of active buy TDST (before offset)
var float        tdst_sel_price = na      // original price of active sell TDST (before offset)
var line         risk_buy_line  = na
var line         risk_sel_line  = na
var float        risk_buy_price = na
var float        risk_sel_price = na
var line         risk_buy_ref_line = na
var line         risk_sel_ref_line = na
var linefill     risk_buy_fill     = na
var linefill     risk_sel_fill     = na

var float        seq_cd_risk_buy_price = na
var float        seq_cd_risk_sel_price = na
var line         seq_cd_risk_buy_line  = na
var line         seq_cd_risk_sel_line  = na
var line         seq_cd_risk_buy_ref_line = na
var line         seq_cd_risk_sel_ref_line = na
var linefill     seq_cd_risk_buy_fill     = na
var linefill     seq_cd_risk_sel_fill     = na

// ── Countdown State (parallel arrays; one entry per active countdown) ─────────
// Each Setup 9 pushes a new entry; countdowns run independently in parallel.
var array<int>   cd_buy_cnts  = array.new<int>()    // current count per active buy countdown
var array<int>   cd_sel_cnts  = array.new<int>()    // current count per active sell countdown
var array<float> cd_buy_b8cls = array.new<float>()  // bar-8 close per active buy countdown
var array<float> cd_sel_b8cls = array.new<float>()  // bar-8 close per active sell countdown
var array<int>   seq_cd_buy_ts    = array.new<int>()     // bar-9 start timestamp per active buy countdown
var array<int>   cd_sel_ts    = array.new<int>()     // bar-9 start timestamp per active sell countdown
var array<float> cd_buy_b5cls = array.new<float>()  // bar-5 close per active buy countdown (8vs5 qualifier)
var array<float> cd_sel_b5cls = array.new<float>()  // bar-5 close per active sell countdown (8vs5 qualifier)

var array<float> seq_cd_sel_peak_th = array.new<float>()  // running-max true high per active sell countdown
var array<float> seq_cd_sel_peak_tl = array.new<float>()  // true low of the bar that set the running-max true high

var array<float> seq_cd_buy_peak_th = array.new<float>()  // true high of the bar that set the running-min true low
var array<float> seq_cd_buy_peak_tl = array.new<float>()  // running-min true low per active buy countdown

// var float offset = 0.01
var float offset = 0
// var float cd_offset = 0.005
var float cd_offset = 0
// var float tdst_offset = 0.002
var float tdst_offset = 0
var tdst_line_style = line.style_dashed
var tdst_line_break_style = line.style_solid
// 完美化信号触发变量
bool isBuyPerfected = false
bool isSellPerfected = false

// Returns true only on the bar whose time matches the stored timestamp.
enable_print_log(int cur_bar_time, int target_year, int target_month, int target_day, string op) =>
    int cur_ymd    = year(cur_bar_time) * 10000 + month(cur_bar_time) * 100 + dayofmonth(cur_bar_time)
    int target_ymd = target_year * 10000 + target_month * 100 + target_day
    switch op
        "<"  => cur_ymd <  target_ymd
        "<=" => cur_ymd <= target_ymd
        ">"  => cur_ymd >  target_ymd
        ">=" => cur_ymd >= target_ymd
        =>     cur_ymd == target_ymd

time_to_yyyymmdd(int cur_bar_time) =>
    str.tostring(year(cur_bar_time) % 100, "00") + str.tostring(month(cur_bar_time), "00") + str.tostring(dayofmonth(cur_bar_time), "00")

// ── True High / True Low ─────────────────────────────────────────────────────
true_high = math.max(high, nz(close[1], high))
true_low  = math.min(low,  nz(close[1], low))

// ── Buy Setup ────────────────────────────────────────────────────────────────
buy_cond = setup_use_equal == "With equal" ? close <= close[setup_look_back] : close < close[setup_look_back]
if buy_cond
    if not buy_done
        buy_cnt += 1
        array.set(buy_bi, buy_cnt - 1, bar_index)
        array.set(buy_lo, buy_cnt - 1, low)
        array.set(buy_hi, buy_cnt - 1, true_high)
        array.set(buy_tl, buy_cnt - 1, true_low)

        if buy_cnt == setup_len
            buy_done := true
            array.push(cd_buy_cnts,  0)
            array.push(cd_buy_b8cls, na)
            array.push(cd_buy_b5cls, na)
            array.push(seq_cd_buy_peak_th, na)
            array.push(seq_cd_buy_peak_tl, na)


            // array.push(seq_cd_buy_ts, time)
            // Sell countdown risk level terminates at Buy Setup 9
            if not na(seq_cd_risk_sel_line)
                line.set_x2(seq_cd_risk_sel_line, bar_index)
                seq_cd_risk_sel_line  := na
                seq_cd_risk_sel_price := na
            if not na(seq_cd_risk_sel_ref_line)
                line.set_x2(seq_cd_risk_sel_ref_line, bar_index)
                seq_cd_risk_sel_ref_line := na

            // 判定 Perfected Buy: 8或9的Low < 6和7的Low
            lo6   = array.get(buy_lo, setup_len - 4)
            lo7   = array.get(buy_lo, setup_len - 3)
            lo8   = array.get(buy_lo, setup_len - 2)
            lo9   = array.get(buy_lo, setup_len - 1)
            min67 = math.min(lo6, lo7)
            if lo8 <= min67 or lo9 <= min67
                isBuyPerfected := true

            
            for i = (show_all_bars == "Active only" ? setup_len - 1 : 0) to setup_len - 1
                if i == setup_len - 1
                    string label_txt = na
                    if enable_setup and enable_perfect_setup
                        if isBuyPerfected
                            label_txt := str.tostring(i + 1) + '\n▲'
                            label_txt
                        else
                            label_txt := str.tostring(i + 1)
                            label_txt
                    else if enable_setup and (not enable_perfect_setup)
                        label_txt := str.tostring(i + 1)
                        label_txt
                    else if (not enable_setup) and enable_perfect_setup
                        if isBuyPerfected
                            label_txt := '▲'
                            label_txt
                    if not na(label_txt)
                        if label_bold == "Bold"
                            buy_label_bar_9 = label.new(x = array.get(buy_bi, i), y = array.get(buy_lo, i) * (1 - offset), text = label_txt, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = setup_buy_color, style = label.style_label_up, size = font_size, text_formatting=text.format_bold)
                             
                        else
                            buy_label_bar_9 = label.new(x = array.get(buy_bi, i), y = array.get(buy_lo, i) * (1 - offset), text = label_txt, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = setup_buy_color, style = label.style_label_up, size = font_size, text_formatting=text.format_none)
                             
                else 
                    if enable_setup
                        string label_txt = str.tostring(i + 1)
                        buy_label_bar_non_9 = label.new(x = array.get(buy_bi, i), y = array.get(buy_lo, i) * (1 - offset), text = label_txt, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = setup_buy_color, style = label.style_label_up, size = font_size, text_formatting=text.format_none)
                         
                        
            // if not immediately perfect, arm deferred watch
            if enable_perfect_setup and not isBuyPerfected
                buy_perf_wait := true
                buy_perf_ref  := min67
            // TDST resistance: highest high of this buy setup
            if enable_tdst
                float setup_max_hi = array.max(buy_hi)
                tdst_buy_price := setup_max_hi
                float final_high = setup_max_hi * (1 + tdst_offset)
                int res_bar_index = array.get(buy_bi, array.indexof(buy_hi, setup_max_hi))
                if not na(tdst_buy_line)
                    line.set_x2(tdst_buy_line, res_bar_index)
                    line.set_extend(tdst_buy_line, extend.none)
                tdst_buy_line := line.new(res_bar_index, final_high, bar_index, final_high, extend=extend.none, color=tdst_res_color, style=tdst_line_style, width=tdst_line_weight)
            
            if enable_risk_level
                float min_tl  = array.min(buy_tl)
                int   ext_idx = array.indexof(buy_tl, min_tl)
                float ext_th  = array.get(buy_hi, ext_idx)
                float rl      = min_tl - (ext_th - min_tl)
                float final_sell_risk_level = rl * (1 - tdst_offset)
                risk_buy_price := rl
                if not na(risk_buy_line)
                    line.set_x2(risk_buy_line, bar_index)
                    line.set_extend(risk_buy_line, extend.none)
                if not na(risk_buy_ref_line)
                    line.set_x2(risk_buy_ref_line, bar_index)
                    line.set_extend(risk_buy_ref_line, extend.none)
                if not na(risk_sel_line)
                    line.set_x2(risk_sel_line, bar_index)
                    line.set_extend(risk_sel_line, extend.none)
                    risk_sel_line := na
                if not na(risk_sel_ref_line)
                    line.set_x2(risk_sel_ref_line, bar_index)
                    line.set_extend(risk_sel_ref_line, extend.none)
                    risk_sel_ref_line := na
                risk_buy_line := line.new(bar_index, final_sell_risk_level, bar_index, final_sell_risk_level, extend=extend.none, color=tdst_res_color, style=line.style_dashed, width=risk_level_line_weight)
                if enable_risk_zone
                    risk_buy_ref_line := line.new(bar_index, close, bar_index, close, extend=extend.none, color=color.new(color.white, 100), width=1)
                    risk_buy_fill := linefill.new(risk_buy_ref_line, risk_buy_line, color=risk_buy_zone_color)
            
            // // SETUP 看看怎么加入允许没有价格翻转的控制箱，芯片上个月连续两个sell 9，且没有价格翻转, 但是perfect（尤其是delay的perfect）是否也要同时停掉，这个得要找点资料研究下
            // if not enable_price_flip
            //     buy_cnt       := 0
            //     buy_done      := false
            //     buy_perf_wait := false
            
else
    buy_cnt  := 0
    buy_done := false


// deferred buy perfection: runs every bar while armed
if buy_perf_wait and low <= buy_perf_ref
    if enable_perfect_setup
        buy_label_perfect = label.new(x = bar_index, y = low * (1 - offset), text = "▲", xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = setup_buy_color, style = label.style_label_up, size = font_size)
    buy_perf_wait := false

// ── Sell Setup ───────────────────────────────────────────────────────────────
sel_cond = setup_use_equal == "With equal" ? close >= close[setup_look_back] : close > close[setup_look_back]
if sel_cond
    if not sel_done
        sel_cnt += 1
        array.set(sel_bi, sel_cnt - 1, bar_index)
        array.set(sel_hi, sel_cnt - 1, high)
        array.set(sel_lo, sel_cnt - 1, true_low)
        array.set(sel_th, sel_cnt - 1, true_high)

        if sel_cnt == setup_len
            sel_done := true
            array.push(cd_sel_cnts,  0)
            array.push(cd_sel_b8cls, na)
            array.push(cd_sel_b5cls, na)
            array.push(seq_cd_sel_peak_th, na)
            array.push(seq_cd_sel_peak_tl, na)

            // array.push(cd_sel_ts,    time)

            // Buy countdown risk level terminates at Sell Setup 9
            if not na(seq_cd_risk_buy_line)
                line.set_x2(seq_cd_risk_buy_line, bar_index)
                seq_cd_risk_buy_line  := na
                seq_cd_risk_buy_price := na
            if not na(seq_cd_risk_buy_ref_line)
                line.set_x2(seq_cd_risk_buy_ref_line, bar_index)
                seq_cd_risk_buy_ref_line := na

            // 判定 Perfected Sell: 8或9的High > 6和7的High
            hi6   = array.get(sel_hi, setup_len - 4)
            hi7   = array.get(sel_hi, setup_len - 3)
            hi8   = array.get(sel_hi, setup_len - 2)
            hi9   = array.get(sel_hi, setup_len - 1)
            max67 = math.max(hi6, hi7)
            if hi8 >= max67 or hi9 >= max67
                isSellPerfected := true
            
            for i = (show_all_bars == "Active only" ? setup_len - 1 : 0) to setup_len - 1 
                if i == setup_len - 1
                    string label_txt = na
                    if enable_setup and enable_perfect_setup
                        if isSellPerfected
                            label_txt := '▼\n'+str.tostring(i + 1)
                            label_txt
                        else
                            label_txt := str.tostring(i + 1)
                            label_txt
                    else if enable_setup and (not enable_perfect_setup)
                        label_txt := str.tostring(i + 1)
                        label_txt
                    else if (not enable_setup) and enable_perfect_setup
                        if isSellPerfected
                            label_txt := '▼'
                            label_txt
                    if not na(label_txt)
                        if label_bold == "Bold"
                            sell_label_bar_9 = label.new(x = array.get(sel_bi, i), y = array.get(sel_hi, i)  * (1 + offset), text = label_txt, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = setup_sell_color, style = label.style_label_down, size = font_size, text_formatting=text.format_bold)
                        else
                            sell_label_bar_9 = label.new(x = array.get(sel_bi, i), y = array.get(sel_hi, i)  * (1 + offset), text = label_txt, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = setup_sell_color, style = label.style_label_down, size = font_size, text_formatting=text.format_none)
                             
                else 
                    if enable_setup
                        string label_txt = str.tostring(i + 1)
                        sell_label_bar_non_9 = label.new(x = array.get(sel_bi, i), y = array.get(sel_hi, i)  * (1 + offset), text = label_txt, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = setup_sell_color, style = label.style_label_down, size = font_size, text_formatting=text.format_none)
                         
            // if not immediately perfect, arm deferred watch
            if enable_perfect_setup and not isSellPerfected
                sel_perf_wait := true
                sel_perf_ref  := max67

            if enable_tdst
                float setup_min_lo = array.min(sel_lo)
                tdst_sel_price := setup_min_lo
                float final_low = setup_min_lo * (1 - tdst_offset)
                int support_bar_index = array.get(sel_bi, array.indexof(sel_lo, setup_min_lo))
                if not na(tdst_sel_line)
                    line.set_x2(tdst_sel_line, support_bar_index)
                    line.set_extend(tdst_sel_line, extend.none)
                tdst_sel_line := line.new(support_bar_index, final_low, bar_index, final_low, extend=extend.none, color=tdst_sup_color, style=tdst_line_style, width=tdst_line_weight)
            
            if enable_risk_level
                float max_th  = array.max(sel_th)
                int   ext_idx = array.indexof(sel_th, max_th)
                float ext_tl  = array.get(sel_lo, ext_idx)
                float rl      = max_th + (max_th - ext_tl)
                float final_buy_risk_level = rl * (1 + tdst_offset)
                risk_sel_price := rl
                if not na(risk_sel_line)
                    line.set_x2(risk_sel_line, bar_index)
                    line.set_extend(risk_sel_line, extend.none)
                if not na(risk_sel_ref_line)
                    line.set_x2(risk_sel_ref_line, bar_index)
                    line.set_extend(risk_sel_ref_line, extend.none)
                if not na(risk_buy_line)
                    line.set_x2(risk_buy_line, bar_index)
                    line.set_extend(risk_buy_line, extend.none)
                    risk_buy_line := na
                if not na(risk_buy_ref_line)
                    line.set_x2(risk_buy_ref_line, bar_index)
                    line.set_extend(risk_buy_ref_line, extend.none)
                    risk_buy_ref_line := na
                risk_sel_line := line.new(bar_index, final_buy_risk_level, bar_index, final_buy_risk_level, extend=extend.none, color=tdst_res_color, style=line.style_dashed, width=risk_level_line_weight)
                if enable_risk_zone
                    risk_sel_ref_line := line.new(bar_index, close, bar_index, close, extend=extend.none, color=color.new(color.white, 100), width=1)
                    risk_sel_fill := linefill.new(risk_sel_line, risk_sel_ref_line, color=risk_sel_zone_color)
            // if not enable_price_flip
            //     sel_cnt       := 0
            //     sel_done      := false
            //     sel_perf_wait := false
                
else
    sel_cnt  := 0
    sel_done := false

// deferred sell perfection: runs every bar while armed
if sel_perf_wait and high >= sel_perf_ref
    if enable_perfect_setup
        sell_label_perfect = label.new(x = bar_index, y = high* (1 + offset), text = "▼", xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = setup_sell_color, style = label.style_label_down, size = font_size)

    sel_perf_wait := false

// ── Extend active TDST lines to current bar, terminate if close crosses ──────
if not na(tdst_buy_line)
    line.set_x2(tdst_buy_line, bar_index)
    if close > tdst_buy_price
        line.set_style(tdst_buy_line, tdst_line_break_style)
        tdst_buy_line := na
        
        
if not na(tdst_sel_line)
    line.set_x2(tdst_sel_line, bar_index)
    if close < tdst_sel_price
        line.set_style(tdst_sel_line, tdst_line_break_style)
        tdst_sel_line := na
        

if not na(risk_buy_line)
    line.set_x2(risk_buy_line, bar_index)
    if not na(risk_buy_ref_line)
        line.set_x2(risk_buy_ref_line, bar_index)
    if close < risk_buy_price
        line.set_style(risk_buy_line, tdst_line_break_style)
        risk_buy_line := na
        risk_buy_ref_line := na

if not na(risk_sel_line)
    line.set_x2(risk_sel_line, bar_index)
    if not na(risk_sel_ref_line)
        line.set_x2(risk_sel_ref_line, bar_index)
    if close > risk_sel_price
        line.set_style(risk_sel_line, tdst_line_break_style)
        risk_sel_line := na
        risk_sel_ref_line := na


if not na(seq_cd_risk_buy_line)
    line.set_x2(seq_cd_risk_buy_line, bar_index)
    if not na(seq_cd_risk_buy_ref_line)
        line.set_x2(seq_cd_risk_buy_ref_line, bar_index)
    if close < seq_cd_risk_buy_price
        line.set_style(seq_cd_risk_buy_line, tdst_line_break_style)
        seq_cd_risk_buy_line     := na
        seq_cd_risk_buy_ref_line := na


// ── Buy Countdown ─────────────────────────────────────────────────────────────
// Each Buy Setup 9 pushes a new entry; all run in parallel.
// Cancelled wholesale when a Sell Setup 9 completes.
// Bar 13 completion uses cd_term_val price; bars 1-12 always use close.
if enable_sequential_countdown and array.size(cd_buy_cnts) > 0
    float buy_cur   = cd_term_val == "Close" ? close : cd_term_val == "Open or Close" ? math.min(open, close) : low
    bool  cd_term_q = cd_compare == "With Equals" ? buy_cur <= low[cd_look_back] : buy_cur < low[cd_look_back]
    bool  cd_std_q  = cd_compare == "With Equals" ? close   <= low[cd_look_back] : close   < low[cd_look_back]
    int i = array.size(cd_buy_cnts) - 1
    while i >= 0
        int cnt = array.get(cd_buy_cnts, i)
        if (cnt > 0) or (cnt == 0 and cd_std_q)  // 要么cnt>0表示bar1已经有了，要么 cnt=0，且当前bar可能构成bar1，那么这两种情况就计算和保留true high和true low
            float cur_peak = array.get(seq_cd_buy_peak_tl, i)
            if na(cur_peak) or true_low < cur_peak
                array.set(seq_cd_buy_peak_tl, i, true_low)
                array.set(seq_cd_buy_peak_th, i, true_high)
                
        if cnt == 12
            float b8c = array.get(cd_buy_b8cls, i)
            // bar 13 candidate: only cd_term_val price qualifies; if it does, check condition 1 then remove
            if cd_term_q
                bool add_label = false

                if enable_13_vs_8
                    if not na(b8c) and low <= b8c
                        add_label := true
                else
                    add_label := true
                
                if add_label
                    string start_time = time_to_yyyymmdd(array.get(seq_cd_buy_ts, i))
                    // label_13_txt = "13" + "\n" + start_time
                    label_13_txt = "13"
                    buy_countdown_label_13 = label.new(x = bar_index, y = low * (1 - cd_offset), text = label_13_txt, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = seq_cd_buy_color, style = label.style_label_up, size = font_size, text_formatting = text.format_bold)
                    
                    if enable_seq_risk_level or enable_seq_risk_zone
                        float peak_th = array.get(seq_cd_buy_peak_th, i)
                        float peak_tl = array.get(seq_cd_buy_peak_tl, i)
                        if not na(peak_th) and not na(peak_tl)
                            float rl = peak_tl - (peak_th - peak_tl)
                            float final_seq_cd_buy_risk_level = rl * (1 - tdst_offset)
                            seq_cd_risk_buy_price := rl
                            if not na(seq_cd_risk_buy_line)
                                line.set_x2(seq_cd_risk_buy_line, bar_index)
                                line.set_extend(seq_cd_risk_buy_line, extend.none)
                            color seq_buy_rl_color = enable_seq_risk_level ? seq_cd_buy_color : color.new(color.white, 100)

                            seq_cd_risk_buy_line := line.new(bar_index, final_seq_cd_buy_risk_level, bar_index, final_seq_cd_buy_risk_level, extend=extend.none, color=seq_buy_rl_color, style=line.style_dashed, width=risk_level_line_weight)
                            if enable_seq_risk_zone
                                if not na(seq_cd_risk_buy_ref_line)
                                    line.set_x2(seq_cd_risk_buy_ref_line, bar_index)
                                    line.set_extend(seq_cd_risk_buy_ref_line, extend.none)
                                seq_cd_risk_buy_ref_line := line.new(bar_index, close, bar_index, close, extend=extend.none, color=color.new(color.white, 100), width=1)
                                seq_cd_risk_buy_fill := linefill.new(seq_cd_risk_buy_ref_line, seq_cd_risk_buy_line, color=risk_buy_zone_color)

                    array.remove(cd_buy_cnts,  i)
                    array.remove(cd_buy_b8cls, i)
                    array.remove(cd_buy_b5cls, i)
                    array.remove(seq_cd_buy_peak_th, i)
                    array.remove(seq_cd_buy_peak_tl, i)
                    // array.remove(seq_cd_buy_ts,    i)
        else
            if cd_std_q
                int new_cnt = cnt + 1
                if new_cnt == 5
                    array.set(cd_buy_cnts, i, new_cnt)
                    array.set(cd_buy_b5cls, i, close)
                else if new_cnt == 8
                    bool set_buy_b8c = not enable_8_vs_5
                    if enable_8_vs_5
                        float b5c = array.get(cd_buy_b5cls, i)
                        set_buy_b8c := not na(b5c) and low <= b5c
                    
                    if set_buy_b8c
                        array.set(cd_buy_b8cls, i, close)
                        array.set(cd_buy_cnts, i, new_cnt)
                else
                    array.set(cd_buy_cnts, i, new_cnt)
        i -= 1
    if show_all_bars == "All" and cd_std_q and array.size(cd_buy_cnts) > 0
        int    last_i    = array.size(cd_buy_cnts) - 1
        int    last_cnt  = array.get(cd_buy_cnts, last_i)
        // if enable_print_log(time, 2022, 03, 16, "<=") and enable_print_log(time, 2022, 01, 24, ">=")
        buy_countdown_label_non_13 = label.new(x = bar_index, y = low * (1 - cd_offset), text = str.tostring(last_cnt), xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = seq_cd_buy_color, style = label.style_label_up, size = font_size, text_formatting = text.format_none)


if not na(seq_cd_risk_sel_line)
    line.set_x2(seq_cd_risk_sel_line, bar_index)
    if not na(seq_cd_risk_sel_ref_line)
        line.set_x2(seq_cd_risk_sel_ref_line, bar_index)
    if close > seq_cd_risk_sel_price
        line.set_style(seq_cd_risk_sel_line, tdst_line_break_style)
        seq_cd_risk_sel_line     := na
        seq_cd_risk_sel_ref_line := na
// ── Sell Countdown ────────────────────────────────────────────────────────────
// Each Sell Setup 9 pushes a new entry; all run in parallel.
// Cancelled wholesale when a Buy Setup 9 completes.
// Bar 13 completion uses cd_term_val price; bars 1-12 always use close.
if enable_sequential_countdown and array.size(cd_sel_cnts) > 0
    float sel_cur   = cd_term_val == "Close" ? close : cd_term_val == "Open or Close" ? math.max(open, close) : high
    bool  cd_term_q = cd_compare == "With Equals" ? sel_cur >= high[cd_look_back] : sel_cur > high[cd_look_back]
    bool  cd_std_q  = cd_compare == "With Equals" ? close   >= high[cd_look_back] : close   > high[cd_look_back]
    int i = array.size(cd_sel_cnts) - 1
    while i >= 0
        int cnt = array.get(cd_sel_cnts, i)

        if (cnt > 0) or (cnt == 0 and cd_std_q)  // 要么cnt>0表示bar1已经有了，要么 cnt=0，且当前bar可能构成bar1，那么这两种情况就计算和保留true high和true low
            float cur_peak = array.get(seq_cd_sel_peak_th, i)
            if na(cur_peak) or true_high > cur_peak
                array.set(seq_cd_sel_peak_th, i, true_high)
                array.set(seq_cd_sel_peak_tl, i, true_low)

        if cnt == 12
            float b8c = array.get(cd_sel_b8cls, i)
 
            if cd_term_q
                bool add_label = false
                if enable_13_vs_8
                    if not na(b8c) and high >= b8c
                        add_label := true
                else
                    add_label := true
                
                if add_label
                    label_13_text = "13"
                    sell_countdown_label_13 = label.new(x = bar_index, y = high * (1 + cd_offset*2), text = label_13_text, xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = seq_cd_sell_color, style = label.style_label_down, size = cd_font_size, text_formatting = text.format_bold)
                    
                    if enable_seq_risk_level or enable_seq_risk_zone
                        float peak_th = array.get(seq_cd_sel_peak_th, i)
                        float peak_tl = array.get(seq_cd_sel_peak_tl, i)
                        if not na(peak_th) and not na(peak_tl)
                            float rl = peak_th + (peak_th - peak_tl)
                            float final_seq_cd_sell_risk_level = rl * (1 + tdst_offset)
                            seq_cd_risk_sel_price := rl
                            if not na(seq_cd_risk_sel_line)
                                line.set_x2(seq_cd_risk_sel_line, bar_index)
                                line.set_extend(seq_cd_risk_sel_line, extend.none)
                            
                            color seq_sell_rl_color = enable_seq_risk_level ? seq_cd_sell_color : color.new(color.white, 100)
                            seq_cd_risk_sel_line := line.new(bar_index, final_seq_cd_sell_risk_level, bar_index, final_seq_cd_sell_risk_level, extend=extend.none, color=seq_sell_rl_color, style=line.style_dashed, width=risk_level_line_weight)
                            if enable_seq_risk_zone
                                if not na(seq_cd_risk_sel_ref_line)
                                    line.set_x2(seq_cd_risk_sel_ref_line, bar_index)
                                    line.set_extend(seq_cd_risk_sel_ref_line, extend.none)
                                seq_cd_risk_sel_ref_line := line.new(bar_index, close, bar_index, close, extend=extend.none, color=color.new(color.white, 100), width=1)
                                seq_cd_risk_sel_fill := linefill.new(seq_cd_risk_sel_line, seq_cd_risk_sel_ref_line, color=color.new(seq_cd_sell_color, 90))
                            
                    array.remove(cd_sel_cnts,  i)
                    array.remove(cd_sel_b8cls, i)
                    array.remove(cd_sel_b5cls, i)
                    array.remove(seq_cd_sel_peak_th, i)
                    array.remove(seq_cd_sel_peak_tl, i)
        else
            // bars 1-12: standard close condition
            if cd_std_q
                int new_cnt = cnt + 1
                
                if new_cnt == 5
                    array.set(cd_sel_b5cls, i, close)
                    array.set(cd_sel_cnts, i, new_cnt)
                else if new_cnt == 8
                    bool set_sell_b8c = not enable_8_vs_5
                    if enable_8_vs_5
                        float b5c = array.get(cd_sel_b5cls, i)
                        set_sell_b8c := not na(b5c) and high >= b5c
                    
                    if set_sell_b8c
                        array.set(cd_sel_cnts, i, new_cnt)
                        array.set(cd_sel_b8cls, i, close)
                else
                    array.set(cd_sel_cnts, i, new_cnt)
        i -= 1
    if show_all_bars == "All" and cd_std_q and array.size(cd_sel_cnts) > 0
        int    last_i   = array.size(cd_sel_cnts) - 1
        int    last_cnt = array.get(cd_sel_cnts, last_i)
        sell_countdown_label_non_13 = label.new(x = bar_index, y = high * (1 + cd_offset), text = str.tostring(last_cnt), xloc = xloc.bar_index, yloc = yloc.price, color = color.new(color.white, 100), textcolor = seq_cd_sell_color, style = label.style_label_down, size = cd_font_size, text_formatting = text.format_none)
